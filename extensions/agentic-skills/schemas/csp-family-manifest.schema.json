{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill Family Manifest (csp.yaml)",
  "description": "Top-level descriptor that groups Agent Skill packages into an executable family. Governed by SKILL_FAMILY_MANIFEST_CONTRACT.md.",
  "type": "object",
  "required": ["family_id", "version", "name", "description", "owner", "phases"],
  "properties": {
    "family_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Globally unique kebab-case identifier for the family."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver MAJOR.MINOR.PATCH."
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "order", "skill_ref", "depends_on"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "order": { "type": "integer", "minimum": 0 },
          "skill_ref": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*@\\^?\\d+\\.\\d+\\.\\d+$",
            "description": "<skill_id>@<version> or <skill_id>@^<version> for semver-compatible ranges."
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "shared_skills": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*@\\^?\\d+\\.\\d+\\.\\d+$"
      }
    },
    "integrations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "lifecycle_hooks": {
      "type": "object",
      "properties": {
        "pre_load":   { "type": "string" },
        "post_load":  { "type": "string" },
        "pre_phase":  { "type": "string" },
        "post_phase": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
