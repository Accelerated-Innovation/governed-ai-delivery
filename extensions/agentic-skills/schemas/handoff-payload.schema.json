{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Handoff Payload",
  "description": "Inter-phase payload accepted by the Handoff Service. Governed by HANDOFF_CONTRACT.md.",
  "type": "object",
  "required": [
    "from_phase",
    "to_phase",
    "family_id",
    "run_id",
    "artifacts",
    "state",
    "trace"
  ],
  "properties": {
    "from_phase": { "type": "string", "minLength": 1 },
    "to_phase": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null", "description": "null only for the final phase in a family run" }
      ]
    },
    "family_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "run_id": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "schema_ref", "content_ref"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "schema_ref": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*@\\d+\\.\\d+\\.\\d+$",
            "description": "<schema_id>@<version> reference into the Schema Registry."
          },
          "content_ref": {
            "type": "string",
            "pattern": "^(s3|https|gs|sha256):.+",
            "description": "URI or content-addressed hash. Inline content is not permitted."
          }
        },
        "additionalProperties": false
      }
    },
    "state": {
      "type": "object",
      "required": ["phase_outputs", "accumulated_context"],
      "properties": {
        "phase_outputs": { "type": "object" },
        "accumulated_context": { "type": "object" }
      },
      "additionalProperties": false
    },
    "trace": {
      "type": "object",
      "required": ["events", "decisions", "approvals_taken"],
      "properties": {
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["timestamp", "event_type", "detail"],
            "properties": {
              "timestamp": {
                "type": "string",
                "description": "ISO-8601 timestamp."
              },
              "event_type": { "type": "string", "minLength": 1 },
              "detail": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["decision_id", "rationale", "alternatives_considered"],
            "properties": {
              "decision_id": { "type": "string" },
              "rationale": { "type": "string" },
              "alternatives_considered": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "approvals_taken": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["approval_id", "approver", "granted_at", "scope"],
            "properties": {
              "approval_id": { "type": "string" },
              "approver": { "type": "string" },
              "granted_at": { "type": "string" },
              "scope": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
