{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Skill Package (skill.json)",
  "description": "Machine-readable contract for a single Agent Skill package. Governed by AGENT_SKILL_PACKAGE_CONTRACT.md. Referenced from a SKILL_FAMILY_MANIFEST phase's skill_ref.",
  "type": "object",
  "required": [
    "skill_id",
    "name",
    "version",
    "supported_modes",
    "allowed_actions",
    "disallowed_actions"
  ],
  "properties": {
    "skill_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Globally unique kebab-case identifier."
    },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "family_ref": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Optional back-pointer to the family this skill belongs to. Shared skills omit this."
    },
    "supported_modes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["interactive", "background"] }
    },
    "required_context": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "disallowed_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tool_permissions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "external_integrations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "output_schemas": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*@\\d+\\.\\d+\\.\\d+$",
        "description": "<schema_id>@<version> reference into the Schema Registry."
      }
    },
    "approval_policy": {
      "type": "object",
      "description": "Per HUMAN_APPROVAL_CONTRACT.md. Free-form object; platform validators may impose further shape."
    },
    "evaluation_policy": {
      "type": "object",
      "description": "Per AGENT_EVALUATION_CONTRACT.md."
    },
    "trigger_support": {
      "type": "array",
      "items": { "type": "string", "enum": ["scheduled", "event"] }
    }
  },
  "additionalProperties": false
}
