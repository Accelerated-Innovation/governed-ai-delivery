            { "src": "instructions/backend/llm-observability.instructions.md", "dest": ".github/instructions/llm-observability.instructions.md" },
            { "src": "prompts/backend/", "dest": ".github/prompts/" },
            { "src": "prompts/backend/genai-preflight.prompt.md", "dest": ".github/prompts/genai-preflight.prompt.md" },
            { "src": "prompts/backend/eval-suite-planning.prompt.md", "dest": ".github/prompts/eval-suite-planning.prompt.md" }
