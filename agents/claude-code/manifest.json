{
  "agent": "claude-code",
  "description": "Claude Code — CLAUDE.md governance, path-scoped rules, and project skills",
  "options": {
    "type": {
      "prompt": "Project type?",
      "choices": ["api", "cli"],
      "default": "api"
    },
    "ui": {
      "prompt": "UI framework?",
      "choices": ["none", "react", "angular"],
      "default": "none"
    },
    "ci": {
      "prompt": "CI platform?",
      "choices": ["github", "azure"],
      "default": "github"
    }
  },
  "variants": {
    "type": {
      "api": {
        "files": [
          { "src": "claude-md/backend-api.md", "dest": "CLAUDE.md" },
          { "src": "rules/backend/api.md", "dest": ".claude/rules/api.md" },
          { "src": "rules/backend/services.md", "dest": ".claude/rules/services.md" },
          { "src": "rules/backend/ports.md", "dest": ".claude/rules/ports.md" },
          { "src": "rules/backend/adapters.md", "dest": ".claude/rules/adapters.md" },
          { "src": "rules/backend/security.md", "dest": ".claude/rules/security.md" },
          { "src": "skills/backend/spec-planning/", "dest": ".claude/skills/spec-planning/" },
          { "src": "skills/backend/architecture-preflight/", "dest": ".claude/skills/architecture-preflight/" },
          { "src": "skills/backend/implementation-plan/", "dest": ".claude/skills/implementation-plan/" },
          { "src": "skills/backend/adr-author/", "dest": ".claude/skills/adr-author/" }
        ],
        "shared": [
          "docs/backend/",
          "features/starter_backend/",
          "features/schema_contract_example/",
          "governance/backend/"
        ]
      },
      "cli": {
        "files": [
          { "src": "claude-md/backend-cli.md", "dest": "CLAUDE.md" },
          { "src": "rules/cli/cli.md", "dest": ".claude/rules/cli.md" },
          { "src": "rules/backend/services.md", "dest": ".claude/rules/services.md" },
          { "src": "rules/backend/ports.md", "dest": ".claude/rules/ports.md" },
          { "src": "rules/backend/adapters.md", "dest": ".claude/rules/adapters.md" },
          { "src": "rules/backend/security.md", "dest": ".claude/rules/security.md" },
          { "src": "skills/backend/spec-planning/", "dest": ".claude/skills/spec-planning/" },
          { "src": "skills/backend/architecture-preflight/", "dest": ".claude/skills/architecture-preflight/" },
          { "src": "skills/backend/implementation-plan/", "dest": ".claude/skills/implementation-plan/" },
          { "src": "skills/backend/adr-author/", "dest": ".claude/skills/adr-author/" }
        ],
        "shared": [
          "docs/backend/",
          "features/starter_cli/",
          "governance/backend/"
        ]
      }
    },
    "ui": {
      "none": {
        "files": [],
        "shared": []
      },
      "react": {
        "files": [
          { "src": "claude-md/ui-react.md", "dest": "CLAUDE-UI.md" },
          { "src": "rules/ui-react/components.md", "dest": ".claude/rules/components.md" },
          { "src": "rules/ui-react/viewmodel.md", "dest": ".claude/rules/viewmodel.md" },
          { "src": "rules/ui-react/api.md", "dest": ".claude/rules/ui-api.md" },
          { "src": "rules/ui-react/accessibility.md", "dest": ".claude/rules/accessibility.md" },
          { "src": "skills/ui/spec-planning/", "dest": ".claude/skills/ui-spec-planning/" },
          { "src": "skills/ui/architecture-preflight/", "dest": ".claude/skills/ui-architecture-preflight/" },
          { "src": "skills/ui/implementation-plan/", "dest": ".claude/skills/ui-implementation-plan/" },
          { "src": "skills/ui/adr-author/", "dest": ".claude/skills/ui-adr-author/" }
        ],
        "shared": [
          "docs/ui/",
          "governance/ui/",
          "features/starter_ui/",
          "features/ui_task_dashboard/"
        ]
      },
      "angular": {
        "files": [
          { "src": "claude-md/ui-angular.md", "dest": "CLAUDE-UI.md" },
          { "src": "rules/ui-angular/components.md", "dest": ".claude/rules/components.md" },
          { "src": "rules/ui-angular/viewmodel.md", "dest": ".claude/rules/viewmodel.md" },
          { "src": "rules/ui-angular/api.md", "dest": ".claude/rules/ui-api.md" },
          { "src": "rules/ui-angular/accessibility.md", "dest": ".claude/rules/accessibility.md" },
          { "src": "skills/ui/spec-planning/", "dest": ".claude/skills/ui-spec-planning/" },
          { "src": "skills/ui/architecture-preflight/", "dest": ".claude/skills/ui-architecture-preflight/" },
          { "src": "skills/ui/implementation-plan/", "dest": ".claude/skills/ui-implementation-plan/" },
          { "src": "skills/ui/adr-author/", "dest": ".claude/skills/ui-adr-author/" }
        ],
        "shared": [
          "docs/ui/",
          "governance/ui/",
          "features/starter_ui/",
          "features/ui_task_dashboard/"
        ]
      }
    },
    "ci": {
      "github": {
        "files": [],
        "shared": ["ci/github/"]
      },
      "azure": {
        "files": [],
        "shared": ["ci/azure/"]
      }
    }
  }
}
