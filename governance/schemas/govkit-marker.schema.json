{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GovKit Marker Schema",
  "description": "Schema for .govkit/marker.json — written by govkit apply / upgrade / stack apply / calibrate. Introduced in PR 1 (Governance Accelerator). The legacy single-file .govkit marker has the same payload shape but lives at .govkit (file) instead of .govkit/marker.json; it is migrated to the directory layout on first read.",
  "type": "object",
  "required": ["version", "level", "agent", "options", "applied_at"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "GovKit version that wrote this marker (PEP 440 / dotted release tag)."
    },
    "level": {
      "type": "string",
      "enum": ["3", "4", "5"],
      "description": "Maturity level: 3=Foundations, 4=Spec-Driven Add-On, 5=GenAI Operations."
    },
    "agent": {
      "type": "string",
      "minLength": 1,
      "description": "Agent target id (e.g. 'claude-code', 'copilot', 'codex')."
    },
    "options": {
      "type": "object",
      "description": "Variant options resolved during apply. `type` and `ci` are required for variant-based manifests; `stack` (PR 2) is enumerated by `govkit stack list`.",
      "required": ["type", "ci"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["api", "cli", "ui-react", "ui-angular", "data"]
        },
        "ci": {
          "type": "string",
          "enum": ["github", "azure"]
        },
        "stack": {
          "type": "string",
          "minLength": 1,
          "description": "Stack overlay id (PR 2). Allowed values are enumerated by `govkit stack list`; schema deliberately keeps this open so user-authored stacks under cli/stacks/ aren't blocked."
        }
      }
    },
    "applied_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the marker was last written. Used by edit-protection (A2) — files modified after this timestamp that carry a govkit:editable header are not overwritten without --force."
    },
    "stack": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["id", "version", "display_name", "applied_at"],
          "additionalProperties": false,
          "properties": {
            "id": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1},
            "display_name": {"type": "string"},
            "applied_at": {"type": "string", "format": "date-time"}
          }
        }
      ],
      "description": "Selected stack overlay metadata (PR 2). Null when no stack has been chosen."
    },
    "assumptions": {
      "type": "array",
      "description": "Load-bearing assumptions made by apply / stack apply / detectors. Populated by PR 3.",
      "items": {"$ref": "#/$defs/assumption"}
    },
    "calibration": {
      "type": "object",
      "description": "Calibration state — when the team last walked the review checklist and what they decided. Populated by PR 5.",
      "required": ["completed_at", "decisions"],
      "additionalProperties": false,
      "properties": {
        "completed_at": {
          "oneOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]
        },
        "decisions": {
          "type": "array",
          "items": {"type": "object"}
        }
      }
    }
  },
  "$defs": {
    "assumption": {
      "type": "object",
      "required": [
        "id", "value", "source", "confidence",
        "evidence", "files_affected", "review_required"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Dotted assumption id, e.g. 'stack.language', 'architecture.style', 'extension.<id>.<capability>'."
        },
        "value": {"type": "string"},
        "source": {
          "type": "string",
          "enum": ["flag", "default", "detected", "prompted", "extension"]
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "evidence": {
          "type": "array",
          "items": {"type": "string"}
        },
        "files_affected": {
          "type": "array",
          "items": {"type": "string"}
        },
        "review_required": {"type": "boolean"},
        "warning_message": {
          "oneOf": [{"type": "null"}, {"type": "string"}]
        },
        "calibrated_at": {
          "oneOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]
        },
        "calibrated_against_overlay_version": {
          "oneOf": [{"type": "null"}, {"type": "string"}]
        }
      }
    }
  }
}
