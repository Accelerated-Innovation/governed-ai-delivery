{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evaluation Prediction Schema",
  "description": "Schema for the evaluation_prediction YAML block embedded in plan.md files. Used by both backend and UI features.",
  "type": "object",
  "required": ["evaluation_prediction"],
  "properties": {
    "evaluation_prediction": {
      "type": "object",
      "required": ["first", "thresholds_met"],
      "properties": {
        "first": {
          "description": "FIRST principle scores for test quality prediction",
          "type": "object",
          "required": ["fast", "isolated", "repeatable", "self_verifying", "timely", "average"],
          "properties": {
            "fast":           { "$ref": "#/$defs/score_entry" },
            "isolated":       { "$ref": "#/$defs/score_entry" },
            "repeatable":     { "$ref": "#/$defs/score_entry" },
            "self_verifying": { "$ref": "#/$defs/score_entry" },
            "timely":         { "$ref": "#/$defs/score_entry" },
            "average":        { "type": "number", "minimum": 0, "maximum": 5 }
          },
          "additionalProperties": false
        },
        "virtues": {
          "description": "7 Code Virtue scores for implementation quality prediction",
          "type": "object",
          "required": ["working", "unique", "simple", "clear", "easy", "developed", "brief", "average"],
          "properties": {
            "working":   { "$ref": "#/$defs/score_entry" },
            "unique":    { "$ref": "#/$defs/score_entry" },
            "simple":    { "$ref": "#/$defs/score_entry" },
            "clear":     { "$ref": "#/$defs/score_entry" },
            "easy":      { "$ref": "#/$defs/score_entry" },
            "developed": { "$ref": "#/$defs/score_entry" },
            "brief":     { "$ref": "#/$defs/score_entry" },
            "average":   { "type": "number", "minimum": 0, "maximum": 5 }
          },
          "additionalProperties": false
        },
        "accessibility": {
          "description": "Accessibility predictions (UI features only)",
          "type": "object",
          "properties": {
            "predicted_axe_violations": { "type": "integer", "minimum": 0 },
            "wcag_level": { "type": "string", "enum": ["A", "AA", "AAA"] }
          },
          "additionalProperties": false
        },
        "llm_evaluation": {
          "description": "L5 LLM-specific evaluation predictions (optional — only for Level 5 features)",
          "type": "object",
          "properties": {
            "criteria": {
              "description": "Provider-neutral predicted evaluation criteria. Use evaluator to identify the configured adapter or oracle.",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["criterion", "evaluator", "predicted_score", "threshold"],
                "properties": {
                  "criterion": { "type": "string", "minLength": 1 },
                  "evaluator": { "type": "string", "minLength": 1 },
                  "predicted_score": { "type": "number", "minimum": 0, "maximum": 1 },
                  "threshold": { "type": "number", "minimum": 0, "maximum": 1 }
                },
                "additionalProperties": false
              }
            },
            "adversarial_required": { "type": "boolean" },
            "guardrail_policy": { "type": "string", "minLength": 1 },
            "retrieval_required": { "type": "boolean" },
            "deepeval_metrics": {
              "description": "Legacy bundled implementation-profile field. Prefer criteria for provider-neutral plans.",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["metric", "predicted_score", "threshold"],
                "properties": {
                  "metric": { "type": "string", "minLength": 1 },
                  "predicted_score": { "type": "number", "minimum": 0, "maximum": 1 },
                  "threshold": { "type": "number", "minimum": 0, "maximum": 1 }
                },
                "additionalProperties": false
              }
            },
            "promptfoo_required": {
              "type": "boolean",
              "description": "Legacy bundled implementation-profile field. Prefer adversarial_required."
            },
            "guardrail_mode": {
              "type": "string",
              "enum": ["nemo", "guardrails-ai", "both", "none"],
              "description": "Legacy bundled implementation-profile field. Prefer guardrail_policy."
            },
            "ragas_required": {
              "type": "boolean",
              "description": "Legacy bundled implementation-profile field. Prefer retrieval_required."
            }
          },
          "additionalProperties": false
        },
        "multi_agent_evaluation": {
          "description": "Multi-agent governance predictions (optional — only for features with multi_agent: true)",
          "type": "object",
          "required": ["topology_validated", "system_prompt_governed"],
          "properties": {
            "topology_validated": {
              "type": "boolean",
              "description": "agent_topology.md was reviewed and approved before implementation"
            },
            "system_prompt_governed": {
              "type": "boolean",
              "description": "All agent system prompts are file-based and declared in agent_topology.md"
            },
            "cross_agent_coherence": { "$ref": "#/$defs/score_entry" },
            "orchestrator_routing_accuracy": { "$ref": "#/$defs/score_entry" }
          },
          "additionalProperties": false
        },
        "thresholds_met": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "score_entry": {
      "type": "object",
      "required": ["score", "evidence"],
      "properties": {
        "score": { "type": "number", "minimum": 1, "maximum": 5 },
        "evidence": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
